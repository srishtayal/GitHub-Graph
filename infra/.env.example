# Local-only development defaults. Copy this file to .env before starting.
POSTGRES_DB=github_graph
POSTGRES_USER=github_graph
POSTGRES_PASSWORD=github_graph

NEO4J_AUTH=neo4j/githubgraph

API_PORT=8080
ANALYSIS_PORT=8000
WEB_PORT=3000

# Optional. Public repository validation works without a token but is rate-limited.
GITHUB_TOKEN=

# Optional until Phase 7 explanations are called.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_SECONDS=30
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BACKOFF_SECONDS=0.5

# Phase 7 prompt and evidence safety bounds.
EXPLANATION_MAX_PROMPT_CHARS=30000
EXPLANATION_MAX_EVIDENCE_CHARS=20000
EXPLANATION_MAX_EVIDENCE_ITEMS=12
EXPLANATION_MAX_REFERENCED_NODES=80
EXPLANATION_MAX_REFERENCED_EDGES=120

REPOSITORY_CLONE_TIMEOUT_SECONDS=120
REPOSITORY_CLONE_MAX_SIZE_BYTES=262144000

# Phase 9: enable this in deployed environments. Use a long random value and
# keep it outside source control. Local development uses a temporary workspace user.
GITHUB_GRAPH_AUTH_ENABLED=false
GITHUB_GRAPH_AUTH_TOKEN_SECRET=replace-with-a-long-random-production-secret
GITHUB_GRAPH_AUTH_TOKEN_TTL_SECONDS=28800
GITHUB_GRAPH_DEVELOPMENT_EMAIL=local@github-graph.dev

# Bound static analysis work for large public repositories.
ANALYSIS_MAX_FILES=15000
ANALYSIS_MAX_SOURCE_FILE_BYTES=2000000
