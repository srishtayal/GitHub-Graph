# Local-only development defaults. Copy this file to .env before starting.
POSTGRES_DB=github_graph
POSTGRES_USER=github_graph
POSTGRES_PASSWORD=github_graph

NEO4J_AUTH=neo4j/githubgraph

API_PORT=8080
ANALYSIS_PORT=8000
WEB_PORT=3000

# Optional. Public repository validation works without a token but is rate-limited.
GITHUB_TOKEN=

# Optional until Phase 7 explanations are called.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

REPOSITORY_CLONE_TIMEOUT_SECONDS=120
REPOSITORY_CLONE_MAX_SIZE_BYTES=262144000
